# ============================================================
# Maverick Bank — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ─── MySQL / AWS RDS ───────────────────────────────────────
MYSQL_ROOT_PASSWORD=MaverickRoot@2024
MYSQL_USER=maverickuser
MYSQL_PASSWORD=Maverick@2024

# For RDS, override DB_URL with your RDS endpoint:
# DB_URL=jdbc:mysql://maverick-bank-db.xxxxxx.ap-south-1.rds.amazonaws.com:3306/maverick_bank?useSSL=true&serverTimezone=UTC

# ─── JWT ───────────────────────────────────────────────────
# MUST be at least 64 characters for HS512
JWT_SECRET=MaverickBankSecretKey2024MaverickBankSecretKey2024MaverickBankSecretKey!!

# ─── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

# ─── Mail (AWS SES) ────────────────────────────────────────
MAIL_HOST=email-smtp.ap-south-1.amazonaws.com
MAIL_USERNAME=AKIAIOSFODNN7EXAMPLE
MAIL_PASSWORD=your-ses-smtp-password
MAIL_FROM=noreply@maverickbank.com

# ─── React Frontend ────────────────────────────────────────
REACT_APP_API_URL=http://localhost:8080/api/v1
